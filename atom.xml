    <link href="http://yoursite.com/2020/07/10/%E7%A7%AF%E5%88%86%E5%99%A8%E9%A5%B1%E5%92%8C%E8%A1%A5%E5%81%BF/"/>
    <id>http://yoursite.com/2020/07/10/%E7%A7%AF%E5%88%86%E5%99%A8%E9%A5%B1%E5%92%8C%E8%A1%A5%E5%81%BF/</id>
