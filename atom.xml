&lt;/blockquote&gt;
&lt;figure class=&quot;highlight plain&quot;&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&quot;gutter&quot;&gt;&lt;pre&gt;&lt;span class=&quot;line&quot;&gt;1&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;2&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;3&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;4&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;5&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;6&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;7&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;8&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;9&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;10&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;11&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;12&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;13&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;14&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;15&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&quot;code&quot;&gt;&lt;pre&gt;&lt;span class=&quot;line&quot;&gt;--+ Project             &amp;#x2F;&amp;#x2F;工程根目录&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;    --+ Drivers         &amp;#x2F;&amp;#x2F;驱动源文件（CubeMX生成）&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;        --+ CMSIS                   &amp;#x2F;&amp;#x2F;ARM的MCU软件接口标准&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;        --+ STM32H7xx_HAL_Driver    &amp;#x2F;&amp;#x2F;H7芯片的HAL库&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;    --+ inc             &amp;#x2F;&amp;#x2F;外设初始化头文件（CubeMX生成）&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;    --+ MDK-ARM         &amp;#x2F;&amp;#x2F;Keil工程目录&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;    --+ Middlewares     &amp;#x2F;&amp;#x2F;第三方软件包&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;    --+ Src             &amp;#x2F;&amp;#x2F;外设初始化源文件（CubeMX生成）&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;    --+ Task            &amp;#x2F;&amp;#x2F;如果有OS的话，该文件夹为任务or线程文件&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;    --+ BSP             &amp;#x2F;&amp;#x2F;BSP文件&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;    --+ REFERENCE       &amp;#x2F;&amp;#x2F;使用到的参考资料（笔者自己添加的）&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;        --+ link.md&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;        --- ...&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;    --+ Project.ioc     &amp;#x2F;&amp;#x2F;CubeMX工程文件&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;    --+ README.md       &amp;#x2F;&amp;#x2F;README文件（笔者自己加的）&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;

